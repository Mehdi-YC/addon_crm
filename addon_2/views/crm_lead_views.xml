<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data>

<!-- ══════════════════════════════════════════════════════════════
     LIST VIEW
══════════════════════════════════════════════════════════════ -->
<record id="crm_lead_list" model="ir.ui.view">
    <field name="name">crm.lead.list</field>
    <field name="model">crm.lead</field>
    <field name="arch" type="xml">
        <list decoration-success="state == 'won'"
              decoration-danger="state == 'lost'"
              decoration-muted="state == 'lost'">
            <field name="ref" optional="show"/>
            <field name="name"/>
            <field name="partner_id"/>
            <field name="category_id" optional="show"/>
            <field name="expected_revenue"/>
            <field name="call_count" string="Calls" optional="show"/>
            <field name="answered_count" string="Answered" optional="hide"/>
            <field name="state" widget="badge"
                   decoration-success="state == 'won'"
                   decoration-warning="state == 'new'"
                   decoration-info="state == 'qualified'"
                   decoration-danger="state == 'lost'"/>
            <field name="user_id" optional="show"/>
            <field name="activity_ids" widget="list_activity" optional="show"/>
        </list>
    </field>
</record>

<!-- ══════════════════════════════════════════════════════════════
     FORM VIEW
══════════════════════════════════════════════════════════════ -->
<record id="crm_lead_form" model="ir.ui.view">
    <field name="name">crm.lead.form</field>
    <field name="model">crm.lead</field>
    <field name="arch" type="xml">
        <form>
            <header>
                <!-- Contextual buttons based on state -->
                <button name="action_qualify"
                        string="Qualify"
                        type="object"
                        class="oe_highlight"
                        invisible="state != 'new'"/>
                <button name="action_send_proposal"
                        string="Send Proposal"
                        type="object"
                        class="oe_highlight"
                        invisible="state != 'qualified'"/>
                <button name="action_won"
                        string="Won"
                        type="object"
                        invisible="state in ['won', 'lost']"/>
                <button name="action_lost"
                        string="Lost"
                        type="object"
                        invisible="state in ['won', 'lost']"/>
                <button name="action_reset_new"
                        string="Reopen"
                        type="object"
                        invisible="state != 'lost'"/>
                <!-- Status bar: shows pipeline stages -->
                <field name="state"
                       widget="statusbar"
                       statusbar_visible="new,qualified,won,lost"/>
            </header>

            <sheet>
                <!-- Smart buttons row (top right) -->
                <div class="oe_button_box" name="button_box">
                    <button name="action_schedule_call"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-phone">
                        <field name="call_count" widget="statinfo" string="Calls"/>
                    </button>
                </div>

                <!-- Record title -->
                <div class="oe_title">
                    <h1>
                        <field name="name" placeholder="Lead name..."/>
                    </h1>
                    <field name="ref" readonly="1" class="text-muted"/>
                </div>

                <!-- Main fields: two columns -->
                <group>
                    <group>
                        <field name="partner_id"/>
                        <field name="user_id"/>
                        <field name="company_id" groups="base.group_multi_company"/>
                    </group>
                    <group>
                        <field name="expected_revenue"/>
                        <field name="category_id"/>
                        <field name="source"/>
                    </group>
                </group>

                <!-- ── TABS ── -->
                <notebook>

                    <!-- TAB 1: Calls -->
                    <page string="Calls" name="calls">
                        <field name="call_ids">
                            <list editable="bottom">
                                <field name="date"/>
                                <field name="duration"/>
                                <field name="answered"/>
                                <field name="response"/>
                            </list>
                        </field>
                    </page>

                    <!-- TAB 2: General Info -->
                    <page string="General Info" name="general">
                        <group>
                            <group string="Contact">
                                <field name="phone" widget="phone"/>
                                <field name="email" widget="email"/>
                                <field name="website" widget="url"/>
                            </group>
                            <group string="Details">
                                <field name="create_date" readonly="1"/>
                            </group>
                        </group>
                        <field name="notes" placeholder="Internal notes..."/>
                    </page>

                    <!-- TAB 3: Interests -->
                    <page string="Interests" name="interests">
                        <field name="interest_ids" widget="many2many_tags"/>
                        <field name="interest_notes"
                               placeholder="Notes about what this lead is interested in..."/>
                    </page>

                </notebook>
            </sheet>

            <!-- Chatter: messages + activities -->
            <div class="oe_chatter">
                <field name="message_follower_ids"/>
                <field name="activity_ids"/>
                <field name="message_ids"/>
            </div>

        </form>
    </field>
</record>

<!-- ══════════════════════════════════════════════════════════════
     KANBAN VIEW
══════════════════════════════════════════════════════════════ -->
<record id="crm_lead_kanban" model="ir.ui.view">
    <field name="name">crm.lead.kanban</field>
    <field name="model">crm.lead</field>
    <field name="arch" type="xml">
        <kanban default_group_by="state" class="o_kanban_small_column">
            <field name="name"/>
            <field name="partner_id"/>
            <field name="expected_revenue"/>
            <field name="state"/>
            <field name="call_count"/>
            <field name="activity_ids"/>
            <templates>
                <t t-name="card">
                    <div class="oe_kanban_global_click">
                        <strong class="o_kanban_record_title">
                            <field name="name"/>
                        </strong>
                        <div class="text-muted o_kanban_record_subtitle">
                            <field name="partner_id"/>
                        </div>
                        <div class="o_kanban_record_bottom">
                            <div class="oe_kanban_bottom_left">
                                <span class="badge bg-light text-dark">
                                    <field name="call_count"/> calls
                                </span>
                            </div>
                            <div class="oe_kanban_bottom_right">
                                <field name="expected_revenue" widget="monetary"/>
                                <field name="activity_ids" widget="kanban_activity"/>
                            </div>
                        </div>
                    </div>
                </t>
            </templates>
        </kanban>
    </field>
</record>

<!-- ══════════════════════════════════════════════════════════════
     SEARCH VIEW
══════════════════════════════════════════════════════════════ -->
<record id="crm_lead_search" model="ir.ui.view">
    <field name="name">crm.lead.search</field>
    <field name="model">crm.lead</field>
    <field name="arch" type="xml">
        <search>
            <!-- Searchable fields -->
            <field name="name" string="Lead"/>
            <field name="ref" string="Reference"/>
            <field name="partner_id"/>
            <field name="category_id"/>
            <field name="user_id"/>

            <!-- Filters -->
            <filter name="my_leads"
                    string="My Leads"
                    domain="[('user_id', '=', uid)]"/>
            <filter name="filter_new"
                    string="New"
                    domain="[('state', '=', 'new')]"/>
            <filter name="filter_qualified"
                    string="Qualified"
                    domain="[('state', '=', 'qualified')]"/>
            <filter name="filter_won"
                    string="Won"
                    domain="[('state', '=', 'won')]"/>
            <filter name="filter_lost"
                    string="Lost"
                    domain="[('state', '=', 'lost')]"/>

            <separator/>

            <filter name="filter_api"
                    string="From API"
                    domain="[('source', '=', 'api')]"/>
            <filter name="filter_high_revenue"
                    string="Revenue &gt; 50k"
                    domain="[('expected_revenue', '&gt;', 50000)]"/>

            <separator/>

            <!-- Group By -->
            <filter name="group_state"
                    string="Status"
                    context="{'group_by': 'state'}"/>
            <filter name="group_category"
                    string="Category"
                    context="{'group_by': 'category_id'}"/>
            <filter name="group_user"
                    string="Salesperson"
                    context="{'group_by': 'user_id'}"/>
            <filter name="group_month"
                    string="Creation Month"
                    context="{'group_by': 'create_date:month'}"/>
        </search>
    </field>
</record>

<!-- ══════════════════════════════════════════════════════════════
     CATEGORY list view (for Configuration menu)
══════════════════════════════════════════════════════════════ -->
<record id="crm_lead_category_list" model="ir.ui.view">
    <field name="name">crm.lead.category.list</field>
    <field name="model">crm.lead.category</field>
    <field name="arch" type="xml">
        <list editable="top">
            <field name="name"/>
            <field name="code"/>
            <field name="active"/>
        </list>
    </field>
</record>

</data>
</odoo>
