<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data>

<!-- ══════════════════════════════════════════════════════════════
     WINDOW ACTIONS
══════════════════════════════════════════════════════════════ -->

<!-- Main leads action: kanban → list → form -->
<record id="action_crm_lead" model="ir.actions.act_window">
    <field name="name">Leads</field>
    <field name="res_model">crm.lead</field>
    <field name="view_mode">kanban,list,form</field>
    <field name="context">{'default_source': 'manual'}</field>
    <field name="help" type="html">
        <p class="o_view_nocontent_smiling_face">
            No leads yet!
        </p>
        <p>
            Create a lead manually or use the Import from API menu
            to fetch leads from your external data source.
        </p>
    </field>
</record>

<!-- Categories action -->
<record id="action_crm_lead_category" model="ir.actions.act_window">
    <field name="name">Lead Categories</field>
    <field name="res_model">crm.lead.category</field>
    <field name="view_mode">list,form</field>
</record>

<!-- Interest tags action -->
<record id="action_crm_lead_interest" model="ir.actions.act_window">
    <field name="name">Interest Tags</field>
    <field name="res_model">crm.lead.interest</field>
    <field name="view_mode">list</field>
</record>

<!-- ══════════════════════════════════════════════════════════════
     SERVER ACTION (bulk — appears in list view Action menu)
══════════════════════════════════════════════════════════════ -->

<record id="action_server_bulk_qualify" model="ir.actions.server">
    <field name="name">Mark as Qualified</field>
    <field name="model_id" ref="model_crm_lead"/>
    <field name="binding_model_id" ref="model_crm_lead"/>
    <field name="binding_view_types">list</field>
    <field name="state">code</field>
    <field name="code">records.action_bulk_qualify()</field>
</record>

<!-- ══════════════════════════════════════════════════════════════
     MENU TREE
══════════════════════════════════════════════════════════════ -->

<!-- 1. Root app (top navigation bar) -->
<menuitem id="menu_crm_root"
          name="CRM"
          sequence="10"/>

<!-- 2. Sales section -->
<menuitem id="menu_crm_sales"
          name="Sales"
          parent="menu_crm_root"
          sequence="10"/>

<!-- 3. Leads list/kanban -->
<menuitem id="menu_crm_leads"
          name="Leads"
          parent="menu_crm_sales"
          action="action_crm_lead"
          sequence="10"/>

<!-- 4. Import wizard -->
<menuitem id="menu_crm_import"
          name="Import from API"
          parent="menu_crm_sales"
          action="action_import_leads_wizard"
          sequence="20"/>

<!-- 5. Configuration section -->
<menuitem id="menu_crm_config"
          name="Configuration"
          parent="menu_crm_root"
          sequence="90"/>

<!-- 6. Categories -->
<menuitem id="menu_crm_categories"
          name="Categories"
          parent="menu_crm_config"
          action="action_crm_lead_category"
          sequence="10"/>

<!-- 7. Interest tags -->
<menuitem id="menu_crm_interests"
          name="Interest Tags"
          parent="menu_crm_config"
          action="action_crm_lead_interest"
          sequence="20"/>

</data>
</odoo>
