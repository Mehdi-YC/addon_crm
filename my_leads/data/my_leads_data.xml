<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Server action bound to list view — opens bulk create wizard -->
        <record id="action_server_bulk_create" model="ir.actions.server">
            <field name="name">Bulk Create</field>
            <field name="model_id" ref="my_leads.model_my_lead"/>
            <field name="binding_model_id" ref="my_leads.model_my_lead"/>
            <field name="binding_view_types">list</field>
            <field name="state">code</field>
            <field name="code">action = model.action_open_bulk_create()</field>
        </record>
    </data>
</odoo>
