<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data>

<!-- ══════════════════════════════════════════════════════
     LIST VIEW
══════════════════════════════════════════════════════ -->
<record id="my_lead_list" model="ir.ui.view">
    <field name="name">my.lead.list</field>
    <field name="model">my.lead</field>
    <field name="arch" type="xml">
        <list decoration-success="state == 'won'"
              decoration-danger="state == 'lost'"
              decoration-muted="state == 'lost'">
            <control>
                <create string="New"/>
                <button string="Bulk Create"
                        name="action_open_bulk_create"
                        type="object"
                        class="btn-secondary"/>
            </control>
            <field name="name"/>
            <field name="store_id" optional="show"/>
            <field name="phone" optional="show"/>
            <field name="website" optional="show"/>
            <field name="is_official" optional="show"/>
            <field name="has_whatsapp" optional="show"/>
            <field name="has_viber" optional="show"/>
            <field name="has_telegram" optional="show"/>
            <field name="call1_answered" string="Call 1" optional="show"/>
            <field name="call2_answered" string="Call 2" optional="show"/>
            <field name="call3_answered" string="Call 3" optional="show"/>
            <field name="accepted" optional="show"/>
            <field name="mail_sent" optional="show"/>
            <field name="state" widget="badge"
                   decoration-warning="state == 'new'"
                   decoration-info="state == 'qualified'"
                   decoration-primary="state == 'proposal'"
                   decoration-success="state == 'won'"
                   decoration-danger="state == 'lost'"/>
            <field name="activity_ids" widget="list_activity"/>
        </list>
    </field>
</record>

<!-- ══════════════════════════════════════════════════════
     FORM VIEW  — status bar + tabs + chatter
══════════════════════════════════════════════════════ -->
<record id="my_lead_form" model="ir.ui.view">
    <field name="name">my.lead.form</field>
    <field name="model">my.lead</field>
    <field name="arch" type="xml">
        <form>
            <header>
                <button name="action_qualify"  string="Qualify"     type="object" class="oe_highlight" invisible="state != 'new'"/>
                <button name="action_proposal" string="Proposition" type="object" class="oe_highlight" invisible="state != 'qualified'"/>
                <button name="action_won"      string="Won"         type="object" invisible="state in ['won','lost']"/>
                <button name="action_lost"     string="Lost"        type="object" invisible="state in ['won','lost']"/>
                <button name="action_reset"    string="Reopen"      type="object" invisible="state != 'lost'"/>
                <field name="state" widget="statusbar"
                       statusbar_visible="new,qualified,proposal,won"/>
            </header>

            <sheet>
                <notebook>

                    <page string="Main Info" name="main">
                        <group>
                            <group string="Identity">
                                <field name="name"/>
                                <field name="store_id"/>
                                <field name="slug"/>
                                <field name="announcement_id"/>
                                <field name="is_official"/>
                            </group>
                            <group string="Contact">
                                <field name="phone" widget="phone"/>
                                <field name="website" widget="url"/>
                                <field name="image_url"/>
                            </group>
                        </group>
                        <group string="Messaging">
                            <field name="has_whatsapp"/>
                            <field name="has_viber"/>
                            <field name="has_telegram"/>
                        </group>
                    </page>

                    <page string="Calls" name="calls">
                        <group string="Call 1">
                            <field name="call1_answered"/>
                            <field name="call1_date"/>
                            <field name="call1_observation" nolabel="1" placeholder="Observation..."/>
                        </group>
                        <group string="Call 2">
                            <field name="call2_answered"/>
                            <field name="call2_date"/>
                            <field name="call2_observation" nolabel="1" placeholder="Observation..."/>
                        </group>
                        <group string="Call 3">
                            <field name="call3_answered"/>
                            <field name="call3_date"/>
                            <field name="call3_observation" nolabel="1" placeholder="Observation..."/>
                        </group>
                    </page>

                    <page string="Final" name="final">
                        <group>
                            <field name="accepted"/>
                            <field name="mail_sent"/>
                        </group>
                        <field name="final_observation" nolabel="1" placeholder="Final observation..."/>
                    </page>

                </notebook>
            </sheet>

            <chatter/>

        </form>
    </field>
</record>

<!-- ══════════════════════════════════════════════════════
     SEARCH VIEW
══════════════════════════════════════════════════════ -->
<record id="my_lead_search" model="ir.ui.view">
    <field name="name">my.lead.search</field>
    <field name="model">my.lead</field>
    <field name="arch" type="xml">
        <search>
            <field name="name"/>
            <field name="store_id" string="Store ID"/>
            <field name="phone"/>
            <filter name="filter_new"       string="New"        domain="[('state','=','new')]"/>
            <filter name="filter_qualified" string="Qualified"  domain="[('state','=','qualified')]"/>
            <filter name="filter_won"       string="Won"        domain="[('state','=','won')]"/>
            <filter name="filter_lost"      string="Lost"       domain="[('state','=','lost')]"/>
            <separator/>
            <filter name="filter_accepted"  string="Accepted"   domain="[('accepted','=',True)]"/>
            <filter name="filter_mail_sent" string="Mail Sent"  domain="[('mail_sent','=',True)]"/>
            <filter name="filter_whatsapp"  string="Has WhatsApp" domain="[('has_whatsapp','=',True)]"/>
            <separator/>
            <filter name="group_state" string="Status" context="{'group_by': 'state'}"/>
        </search>
    </field>
</record>

<!-- ══════════════════════════════════════════════════════
     WIZARD FORM VIEW
══════════════════════════════════════════════════════ -->
<record id="my_lead_bulk_wizard_form" model="ir.ui.view">
    <field name="name">my.lead.bulk.wizard.form</field>
    <field name="model">my.lead.bulk.wizard</field>
    <field name="arch" type="xml">
        <form string="Bulk Create Leads">
            <sheet>
                <group>
                    <field name="keyword" placeholder="e.g. Algiers, Q1, Campaign..."/>
                </group>
                <p class="text-muted">
                    Creates 2 leads with random names, phones and emails.
                    The keyword will appear in both lead names.
                </p>
            </sheet>
            <footer>
                <button name="action_create" string="Create 2 Leads"
                        type="object" class="btn-primary"/>
                <button string="Cancel" class="btn-secondary" special="cancel"/>
            </footer>
        </form>
    </field>
</record>

<!-- ══════════════════════════════════════════════════════
     ACTIONS
══════════════════════════════════════════════════════ -->
<record id="action_my_lead" model="ir.actions.act_window">
    <field name="name">Leads</field>
    <field name="res_model">my.lead</field>
    <field name="view_mode">list,form</field>
    <field name="help" type="html">
        <p class="o_view_nocontent_smiling_face">
            No leads yet. Click Bulk Create to generate some!
        </p>
    </field>
</record>

<!-- ══════════════════════════════════════════════════════
     MENUS
══════════════════════════════════════════════════════ -->
<menuitem id="menu_my_leads_root" name="My Leads" sequence="10"/>
<menuitem id="menu_my_leads_list" name="Leads"    parent="menu_my_leads_root"
          action="action_my_lead" sequence="10"/>

</data>
</odoo>
