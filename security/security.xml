<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- CRM Store User Group -->
    <record id="group_crm_store_user" model="res.groups">
        <field name="name">Store CRM User</field>
        <field name="category_id" ref="base.module_category_crm" />
    </record>

    <!-- CRM Store Admin Group -->
    <record id="group_crm_store_admin" model="res.groups">
        <field name="name">Store CRM Admin</field>
        <field name="category_id" ref="base.module_category_crm" />
    </record>

    <!-- Access for Store CRM User -->
    <record id="access_crm_store_user" model="ir.model.access">
        <field name="name">crm_store User Access</field>
        <field name="model_id" ref="model_crm_store" />
        <field name="group_id" ref="base.group_user" />
        <field name="perm_read">True</field>
        <field name="perm_write">True</field>
        <field name="perm_create">True</field>
        <field name="perm_unlink">False</field>
    </record>

    <!-- Access for System User (Admin) -->
    <record id="access_crm_store_admin" model="ir.model.access">
        <field name="name">crm_store Admin Access</field>
        <field name="model_id" ref="model_crm_store" />
        <field name="group_id" ref="base.group_system" />
        <field name="perm_read">True</field>
        <field name="perm_write">True</field>
        <field name="perm_create">True</field>
        <field name="perm_unlink">True</field>
    </record>

</odoo>