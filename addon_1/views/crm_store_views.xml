<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- LIST VIEW -->
    <record id="view_crm_store_list" model="ir.ui.view">
        <field name="name">crm.store.list</field>
        <field name="model">crm_store</field>
        <field name="arch" type="xml">
            <list>
                <field name="store_id" />
                <field name="name" />
                <field name="phone" />
                <field name="is_official" widget="boolean"/>
                <field name="accepted" widget="boolean"/>
                <field name="call1_answered" widget="boolean"/>
                <field name="call2_answered" widget="boolean"/>
                <field name="call3_answered" widget="boolean"/>
                <field name="mail_sent" widget="boolean"/>
            </list>
        </field>
    </record>

    <!-- FORM VIEW -->
    <record id="view_crm_store_form" model="ir.ui.view">
        <field name="name">crm.store.form</field>
        <field name="model">crm_store</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_log_call" type="object" string="Log Call" class="btn-primary"/>
                    <button name="action_send_mail" type="object" string="Send Mail" class="btn-info"/>
                    <field name="accepted" widget="statusbar" statusbar_visible="accepted"/>
                </header>

                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Store Name"/></h1>
                    </div>

                    <group>
                        <group>
                            <field name="store_id"/>
                            <field name="slug"/>
                            <field name="is_official"/>
                            <field name="announcement_id"/>
                        </group>
                        <group>
                            <field name="website" widget="url"/>
                            <field name="phone" widget="phone"/>
                            <field name="image_url"/>
                        </group>
                    </group>

                    <notebook>
                        <page name="communication" string="Communication">
                            <group>
                                <field name="has_whatsapp"/>
                                <field name="has_viber"/>
                                <field name="has_telegram"/>
                            </group>
                        </page>

                        <page name="calls" string="Call History">
                            <field name="call1_answered"/>
                            <field name="call1_date"/>
                            <field name="call1_observation"/>
                            <field name="call2_answered"/>
                            <field name="call2_date"/>
                            <field name="call2_observation"/>
                            <field name="call3_answered"/>
                            <field name="call3_date"/>
                            <field name="call3_observation"/>
                        </page>

                        <page name="final" string="Final Decision">
                            <group>
                                <field name="mail_sent"/>
                                <field name="final_observation"/>
                            </group>
                        </page>
                    </notebook>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- KANBAN VIEW -->
    <record id="view_crm_store_kanban" model="ir.ui.view">
        <field name="name">crm.store.kanban</field>
        <field name="model">crm_store</field>
        <field name="arch" type="xml">
            <kanban default_group_by="accepted">
                <field name="name"/>
                <field name="store_id"/>
                <field name="phone"/>
                <field name="is_official"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_card_header">
                            <div class="oe_kanban_card_header_title">
                                <field name="name"/>
                            </div>
                        </div>
                        <div class="oe_kanban_card_content">
                            <div>ID: <field name="store_id"/></div>
                            <div>Phone: <field name="phone"/></div>
                            <div>Official: <field name="is_official"/></div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- SEARCH VIEW -->
    <record id="view_crm_store_search" model="ir.ui.view">
        <field name="name">crm.store.search</field>
        <field name="model">crm_store</field>
        <field name="arch" type="xml">
            <search>
                <field name="store_id"/>
                <field name="name"/>
                <field name="phone"/>
                <field name="website"/>
                <separator/>
                <filter name="official" string="Official" domain="[('is_official', '=', True)]"/>
                <filter name="accepted" string="Accepted" domain="[('accepted', '=', True)]"/>
                <filter name="pending" string="Pending" domain="[('accepted', '=', False)]"/>
                <filter name="mail_sent" string="Mail Sent" domain="[('mail_sent', '=', True)]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter name="group_official" string="Official" context="{'group_by': 'is_official'}"/>
                    <filter name="group_accepted" string="Accepted" context="{'group_by': 'accepted'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- MAIN ACTION -->
    <record id="action_crm_store" model="ir.actions.act_window">
        <field name="name">Store CRM</field>
        <field name="res_model">crm_store</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="search_view_id" ref="view_crm_store_search"/>
        <field name="context">{'search_default_pending': 1}</field>
    </record>

</odoo>