<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- LIST VIEW -->
    <record id="view_crm_store_list" model="ir.ui.view">
        <field name="name">crm.store.list</field>
        <field name="model">crm_store</field>
        <field name="arch" type="xml">
            <list>
                <field name="store_id" />
                <field name="name" />
                <field name="phone" />
                <field name="is_official" widget="boolean"/>
                <field name="accepted" widget="boolean"/>
                <field name="call1_answered" widget="boolean"/>
                <field name="call2_answered" widget="boolean"/>
                <field name="call3_answered" widget="boolean"/>
                <field name="mail_sent" widget="boolean"/>
            </list>
        </field>
    </record>

    <!-- FORM VIEW -->
    <record id="view_crm_store_form" model="ir.ui.view">
        <field name="name">crm.store.form</field>
        <field name="model">crm_store</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_log_call" type="object" string="Log Call" class="btn-primary" icon="fa-phone"/>
                    <button name="action_send_mail" type="object" string="Send Mail" class="btn-info" icon="fa-envelope"/>
                </header>

                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" class="oe_inline" placeholder="Store Name"/></h1>
                    </div>

                    <div class="oe_button_box" name="button_box">
                        <button name="action_log_call" type="object" class="oe_stat_button" icon="fa-phone">
                            <span>Log Call</span>
                        </button>
                        <button name="action_mark_accepted" type="object" class="oe_stat_button" icon="fa-check" invisible="accepted">
                            <span>Mark Accepted</span>
                        </button>
                    </div>

                    <notebook>
                        <page string="Main Information">
                            <group>
                                <group string="Store Details">
                                    <field name="store_id"/>
                                    <field name="slug"/>
                                    <field name="is_official" widget="boolean"/>
                                    <field name="announcement_id"/>
                                </group>
                                <group string="Contact Information">
                                    <field name="website" widget="url"/>
                                    <field name="phone" widget="phone"/>
                                    <field name="image_url"/>
                                </group>
                            </group>
                        </page>

                        <page string="Communication Channels">
                            <group>
                                <group string="Available Channels">
                                    <field name="has_whatsapp" widget="boolean"/>
                                    <field name="has_viber" widget="boolean"/>
                                    <field name="has_telegram" widget="boolean"/>
                                </group>
                            </group>
                        </page>

                        <page string="Call History">
                            <group>
                                <group string="Call 1" colspan="2">
                                    <field name="call1_answered" widget="boolean"/>
                                    <field name="call1_date"/>
                                    <field name="call1_observation" widget="text" nolabel="1" colspan="2"/>
                                </group>
                                <group string="Call 2" colspan="2">
                                    <field name="call2_answered" widget="boolean"/>
                                    <field name="call2_date"/>
                                    <field name="call2_observation" widget="text" nolabel="1" colspan="2"/>
                                </group>
                                <group string="Call 3" colspan="2">
                                    <field name="call3_answered" widget="boolean"/>
                                    <field name="call3_date"/>
                                    <field name="call3_observation" widget="text" nolabel="1" colspan="2"/>
                                </group>
                            </group>
                        </page>

                        <page string="Final Decision">
                            <group>
                                <field name="accepted" widget="boolean"/>
                                <field name="mail_sent" widget="boolean"/>
                                <field name="final_observation" widget="text" nolabel="1" colspan="2"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- KANBAN VIEW -->
    <record id="view_crm_store_kanban" model="ir.ui.view">
        <field name="name">crm.store.kanban</field>
        <field name="model">crm_store</field>
        <field name="arch" type="xml">
            <kanban default_group_by="accepted">
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_card">
                            <div class="oe_kanban_content">
                                <h4><a type="open"><field name="name"/></a></h4>
                                <p><strong>ID:</strong> <field name="store_id"/></p>
                                <p><strong>Phone:</strong> <field name="phone"/></p>
                                <p><strong>Official:</strong> <field name="is_official" widget="boolean"/></p>
                                <p><strong>Calls Logged:</strong>
                                    <field name="call1_answered" widget="boolean"/>
                                    <field name="call2_answered" widget="boolean"/>
                                    <field name="call3_answered" widget="boolean"/>
                                </p>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- SEARCH VIEW -->
    <record id="view_crm_store_search" model="ir.ui.view">
        <field name="name">crm.store.search</field>
        <field name="model">crm_store</field>
        <field name="arch" type="xml">
            <search>
                <field name="store_id" string="Store ID"/>
                <field name="name" string="Store Name"/>
                <field name="phone"/>
                <field name="website"/>
                <separator/>
                <filter name="filter_official" string="Official Stores" domain="[('is_official', '=', True)]"/>
                <filter name="filter_accepted" string="Accepted" domain="[('accepted', '=', True)]"/>
                <filter name="filter_pending" string="Pending" domain="[('accepted', '=', False)]"/>
                <filter name="filter_mail_sent" string="Mail Sent" domain="[('mail_sent', '=', True)]"/>
                <filter name="filter_call1" string="Call 1 Answered" domain="[('call1_answered', '=', True)]"/>
                <filter name="filter_call2" string="Call 2 Answered" domain="[('call2_answered', '=', True)]"/>
                <filter name="filter_call3" string="Call 3 Answered" domain="[('call3_answered', '=', True)]"/>
                <separator/>
                <group expand="1" string="Group By">
                    <filter name="group_by_official" string="Official Status" context="{'group_by': 'is_official'}"/>
                    <filter name="group_by_accepted" string="Acceptance" context="{'group_by': 'accepted'}"/>
                    <filter name="group_by_mail_sent" string="Mail Sent" context="{'group_by': 'mail_sent'}"/>
                    <filter name="group_by_call1_date" string="Call 1 Date" context="{'group_by': 'call1_date'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- MAIN ACTION -->
    <record id="action_crm_store" model="ir.actions.act_window">
        <field name="name">Store CRM</field>
        <field name="res_model">crm_store</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="search_view_id" ref="view_crm_store_search"/>
        <field name="context">{'search_default_filter_pending': 1}</field>
    </record>

</odoo>